# URL publica con la que se generan los links de invitacion (QR de Usuarios).
# Si no se define, se usa window.location.origin (el dominio desde el que se sirve la app).
# Fijala en produccion para que el link no dependa del host que sirvio la pagina
# (proxy, IP interna, ngrok, etc.) y sobreviva a un cambio de dominio.
VITE_APP_URL=https://sicodiet.com
