# ==========================================
# SiCoDiEt - Variables de Entorno
# ==========================================
# Copiar este archivo a .env y completar los valores

# --- Aplicación ---
NODE_ENV=production
PORT=3001

# --- Base de Datos ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=sicodiet
DB_PASSWORD=secret
DB_NAME=gestion_tambo

# --- JWT ---
JWT_SECRET=cambia_esto_por_un_secreto_real
JWT_EXPIRES_IN=24h

# --- Frontend URL (CORS) ---
# Agregar URLs separadas por comas:
# - Backend local: http://localhost:3001
# - Red local: http://192.168.1.244:3001
# - Ngrok: https://xxxx.ngrok-free.dev
# - Tunnel permanente: https://tu-app.tunnel.com
FRONTEND_URL=http://localhost:3001,http://192.168.1.244:3001

# --- Puerto para testing móvil con ngrok ---
NGROK_PORT=3002

# --- Email (Password Reset) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_app_password_de_gmail
EMAIL_FROM="SiCoDiEt" <tu_email@gmail.com>
RESET_TOKEN_EXPIRY=1
